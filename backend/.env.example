# Backend Environment Variables
# Copy to .env and fill in your values

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/traveloop

# Sync URL for Alembic migrations (uses psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/traveloop

# JWT Configuration
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:5173

# App
APP_NAME=Traveloop
DEBUG=true
